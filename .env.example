# ── Supabase (pre-computed cache) ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ── Gemini (global executive summary) ────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Ollama (local LLM for micro-narratives) ──────────────────────────────────
# WSL2 users: set this to your Windows host IP (ipconfig → vEthernet adapter)
OLLAMA_HOST=172.21.80.1
